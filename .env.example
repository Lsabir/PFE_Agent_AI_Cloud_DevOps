# ── AZURE KEY VAULT (obligatoire) ────────────────────────────────────────────
# L'URL du vault. Tous les secrets sont lus automatiquement depuis KV.
AZURE_KEYVAULT_URL=https://agent-devops-kv-pfe2.vault.azure.net/

# Pour désactiver KV et utiliser les variables ci-dessous (dev sans KV) :
# USE_KEYVAULT=false

# ── CONFIG NON-SENSIBLE ───────────────────────────────────────────────────────
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview
GITHUB_INFRA_REPO=infra-provisioned
DEFAULT_LOCATION=swedencentral
DEFAULT_ENVIRONMENT=dev
NAMING_PREFIX=infra-prov

# ── FALLBACK LOCAL (uniquement si USE_KEYVAULT=false) ────────────────────────
# Ne remplir que pour tester en local sans accès Key Vault.
# Ne JAMAIS committer ces valeurs.
# JIRA_URL=https://your-domain.atlassian.net
# JIRA_EMAIL=your-email@example.com
# JIRA_API_TOKEN=your_jira_api_token
# JIRA_PROJECT_KEY=PM
# AZURE_OPENAI_ENDPOINT=https://your-openai-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key
# GITHUB_TOKEN=your_github_personal_access_token
# GITHUB_OWNER=your_github_username
