# .env.autonomous
# Configuration pour l'exécution autonome de l'Agent IA DevOps
# Copier ce fichier en .env et remplir les valeurs

# ── Mode autonome ─────────────────────────────────────────────────────────
# Activez le mode CI complet (pas de confirmations)
AGENT_CI_MODE=true

# Validez automatiquement les plans sans confirmation
AGENT_SKIP_VALIDATION=true

# Validez automatiquement les analyses (pas de pause)
AGENT_AUTO_VALIDATE_PLAN=true

# (Optionnel) Forcez un ticket spécifique au lieu du premier
# AGENT_TICKET=PM-3

# ── Configuration Azure OpenAI ────────────────────────────────────────────
# Endpoint Azure OpenAI (ex: https://agent-devops-openai.openai.azure.com/)
AZURE_OPENAI_ENDPOINT=https://agent-devops-openai.openai.azure.com/

# Clé API Azure OpenAI (stockée normalement dans Key Vault)
AZURE_OPENAI_KEY=your_key_here

# Deployment name du modèle GPT-4 sur Azure OpenAI
AZURE_OPENAI_DEPLOYMENT=gpt-4

# Version de l'API OpenAI
OPENAI_API_VERSION=2024-02-15-preview

# ── GitHub Configuration ──────────────────────────────────────────────────
# Token GitHub avec accès repo (stocké normalement dans Key Vault)
GITHUB_TOKEN=ghp_your_token_here

# Propriétaire du repo infra-provisioned
GITHUB_OWNER=Lsabir

# Nom du repo pour l'infrastructure
GITHUB_INFRA_REPO=infra-provisioned

# URL de base GitHub
GITHUB_API_URL=https://api.github.com

# ── Jira Configuration ────────────────────────────────────────────────────
# URL de base Jira (ex: https://abdessamad1sabir.atlassian.net)
JIRA_URL=https://abdessamad1sabir.atlassian.net

# Token API Jira (stocké normalement dans Key Vault)
JIRA_TOKEN=your_jira_token_here

# Email utilisateur Jira
JIRA_EMAIL=your_email@example.com

# Clé du projet Jira (ex: PM)
JIRA_PROJECT_KEY=PM

# ── Azure Configuration ───────────────────────────────────────────────────
# Subscription ID Azure
AZURE_SUBSCRIPTION_ID=your_subscription_id

# Resource Group pour les secrets Key Vault
AZURE_KEYVAULT_NAME=agent-devops-kv-pfe2

# Tenant ID Azure
AZURE_TENANT_ID=your_tenant_id

# ── Logging & Debug ───────────────────────────────────────────────────────
# Niveau de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Activer les logs verbeux
DEBUG=false

# ── Timeouts ──────────────────────────────────────────────────────────────
# Timeout pour attendre les résultats du pipeline (minutes)
PIPELINE_TIMEOUT_MINUTES=15

# Intervalle de polling du pipeline (secondes)
PIPELINE_POLL_INTERVAL=10

# ── Comportement avancé ───────────────────────────────────────────────────
# Auto-retry en cas d'erreur transiente
AUTO_RETRY_ON_FAILURE=true

# Nombre maximum de retries
MAX_RETRIES=3

# Attendre que le terraform apply soit complètement terminé
WAIT_FOR_APPLY_COMPLETION=true
